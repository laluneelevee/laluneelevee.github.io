{
    "0": {
        "text": "騒がしいこの世の雑音", 
        "name": "", 
        "loc": "center"
    }, 
    "1": {
        "text": "ノイズキャンセル機能付きのヘッドフォンを買ったんだ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "2": {
        "text": "あら、そうですか", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "3": {
        "text": "良いだろう", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "4": {
        "text": "えぇ、そうですね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "5": {
        "text": "羨ましい？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "6": {
        "text": "そうでもありません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "7": {
        "text": "今日びノイズキャンセルなんて珍しい機能でもないでしょう", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "8": {
        "text": "そうかな", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "9": {
        "text": "電車に乗るときなんて便利だよ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "10": {
        "text": "私は電車に乗る際に音楽を聴きません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "11": {
        "text": "自宅にいるときだけですね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "12": {
        "text": "そりゃそうか", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "13": {
        "text": "えぇ、ですからノイズキャンセルをする必要がありませんね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "14": {
        "text": "私の場合ですが", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "15": {
        "text": "電車内はものすごく騒がしいですからね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "16": {
        "text": "ノイズをキャンセルしたい気持ちはまぁ理解できます", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "17": {
        "text": "ノイズキャンセルってどういう仕組みなの？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "18": {
        "text": "ノイズと逆位相の波長を流して、打ち消しているのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "19": {
        "text": "シンプルな手法ですね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "20": {
        "text": "うーん、それだけじゃよく分からないから、もう少し説明してくれない", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "21": {
        "text": "大層なことではないのですけれどね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "22": {
        "text": "まず、周囲の音をマイクで集音します", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "23": {
        "text": "うん", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "24": {
        "text": "この音には聴いている音楽に周囲のノイズが加わった音になります", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "25": {
        "text": "なるほどね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "26": {
        "text": "では、どうしたら、雑音を取り出せますか？", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "27": {
        "text": "簡単だ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "28": {
        "text": "元の音楽を引けば良い", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "29": {
        "text": "その通りです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "30": {
        "text": "集音したデータから、オリジナルの音源データの差分をとります", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "31": {
        "text": "するとノイズだけが抽出できます", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "32": {
        "text": "ふーん", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "33": {
        "text": "後は簡単ですね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "34": {
        "text": "ノイズを反転して、逆位相のノイズをつくりだします", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "35": {
        "text": "これを元のノイズ入りの音に加えることでノイズがキャンセルされます", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "36": {
        "text": "最後の方はよく分からなかったけれど、大体は分かったかな", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "37": {
        "text": "難しい話はしておりません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "38": {
        "text": "だろうね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "39": {
        "text": "話し手はそう言うものだ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "40": {
        "text": "この作業を一瞬でおこなうことにより、ノイズがキャンセルされたように聞こえるのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "41": {
        "text": "なるほどね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "42": {
        "text": "面白いね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "43": {
        "text": "要はヘッドフォンにもマイクが付いているってことだろう？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "44": {
        "text": "その通りです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "45": {
        "text": "一方的に喋るだけじゃなくて、聴くこともできるってわけだ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "46": {
        "text": "聴いてみる？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "47": {
        "text": "いいえ、結構です", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "48": {
        "text": "どうして？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "49": {
        "text": "どうしてでしょうか", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "50": {
        "text": "あなたの声が聞こえなくなるから", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "51": {
        "text": "え？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "52": {
        "text": "冗談ですよ", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "53": {
        "text": "わざわざ、ノイズを消してまで音楽を聴こうと思わないだけです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "54": {
        "text": "なんだか作り物のような感じがしませんか？", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "55": {
        "text": "どうだろう……", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "56": {
        "text": "没入感があると思うけれど", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "57": {
        "text": "なるほど", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "58": {
        "text": "集中力を高めたいわけですね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "59": {
        "text": "まぁ、そうだね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "60": {
        "text": "周囲が気にならなくなる", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "61": {
        "text": "ユータさんは周囲を気にしながら、生活されているわけですね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "62": {
        "text": "そうかもしれない", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "63": {
        "text": "それで何をされるのでしょうか？", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "64": {
        "text": "勉強かな", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "65": {
        "text": "ふふ、本当でしょうか？", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "66": {
        "text": "どうだろうね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "67": {
        "text": "自分の空間がほしいだけかもしれない", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "68": {
        "text": "パーソナルスペースですね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "69": {
        "text": "そうだね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "70": {
        "text": "都会はパーソナルスペースがありませんからね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "71": {
        "text": "なるほど、聴覚の観点からスペースを確保するわけですか", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "72": {
        "text": "ノイズを削除することにより、聴覚的な空間を確保するというわけですね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "73": {
        "text": "理解できました", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "74": {
        "text": "あ、そう", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "75": {
        "text": "現代人らしいなと", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "76": {
        "text": "そうかな", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "77": {
        "text": "えぇ、潜在的に自由を欲しているのでしょう", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "78": {
        "text": "静かな場所がないから、強制的に作り出す", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "79": {
        "text": "そういう指向性です", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "80": {
        "text": "静かな場所はないね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "81": {
        "text": "そうでしょう", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "82": {
        "text": "これだけ人が集まれば仕方のないことです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "83": {
        "text": "さらに面白いのは、音楽を聴いていなければならないという点です", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "84": {
        "text": "どういうこと？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "85": {
        "text": "音楽で誤魔化しているのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "86": {
        "text": "真の意味での静かさは得られない", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "87": {
        "text": "確かに音楽を流していないと軽減はされるけれど、ノイズは聴こえるね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "88": {
        "text": "でしょう", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "89": {
        "text": "静寂を作ることはできないのかな？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "90": {
        "text": "そういうわけではありませんよ", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "91": {
        "text": "音楽を聴くという前提があるので、一定以上の音はキャンセルされないのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "92": {
        "text": "どうして？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "93": {
        "text": "大きな音を打ち消すには同じだけ大きな音を出さなければいけないからです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "94": {
        "text": "スピーカの限界もありますし、間違ったら、大音量が流れてしまいます", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "95": {
        "text": "マイクのハウリングのように", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "96": {
        "text": "うわぁ、それは怖いな", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "97": {
        "text": "安全設計されているのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "98": {
        "text": "完璧が正しいとは限らないというわけです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "99": {
        "text": "じゃあ、どうしたら、静かになれるのかな", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "100": {
        "text": "静かなところに移動するのが、最も簡単な方法でしょう", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "101": {
        "text": "元も子もないな", 
        "name": "ユータ", 
        "loc": "right"
    }
}