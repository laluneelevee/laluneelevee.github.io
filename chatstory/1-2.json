{
    "0": {
        "text": "知人と友人はどう違う？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "1": {
        "text": "明確な基準はありません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "2": {
        "text": "そうですね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "3": {
        "text": "イメージとしては、自分を中心として、知り合いの人間が散らばっているのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "4": {
        "text": "想像できましたか？", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "5": {
        "text": "うん", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "6": {
        "text": "近しい人ほど、自分の近くにいるのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "7": {
        "text": "それは物理的な近さでもあるし、心理的な距離でもあります", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "8": {
        "text": "今、俺たちは物理的には近いけれど、心理的には遠い", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "9": {
        "text": "そうですね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "10": {
        "text": "そうやって、距離をイメージしたときに近くにいる人間を集めた集合を友人と定義します", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "11": {
        "text": "その外は知人なわけだ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "12": {
        "text": "そうです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "13": {
        "text": "なるほどね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "14": {
        "text": "じゃあ、どこまでを友人に含めるかは人によって異なるわけだ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "15": {
        "text": "その通りです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "16": {
        "text": "納得がいったよ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "17": {
        "text": "これは誰が考えたの？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "18": {
        "text": "私が考えました", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "19": {
        "text": "そうなんだ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "20": {
        "text": "すごいね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "21": {
        "text": "そうですか？", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "22": {
        "text": "もの凄く単純化していますよ", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "23": {
        "text": "そんな風に考えたことはなかった", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "24": {
        "text": "やっぱり、面白い人だ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "25": {
        "text": "この様な考え方はあまり好まれません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "26": {
        "text": "人に順位をつけているから？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "27": {
        "text": "そうです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "28": {
        "text": "でもさ、どうしたって、無意識の内に順位をつけているものじゃないかな？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "29": {
        "text": "そうですね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "30": {
        "text": "平等という言葉に囚われ過ぎているのかもしれません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "31": {
        "text": "何ていうか凄いことを言うね", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "32": {
        "text": "この程度は凄くありません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "33": {
        "text": "でも、誰もそんなことを言わないよ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "34": {
        "text": "ヒエヌキさんが初めてだ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "35": {
        "text": "あなたの見識を深められたのであれば、重畳です", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "36": {
        "text": "チョージョーだって", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "37": {
        "text": "変ですか？", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "38": {
        "text": "俺なら言わない", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "39": {
        "text": "そうですか", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "40": {
        "text": "私は割と使用します", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "41": {
        "text": "何と比べて？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "42": {
        "text": "マジで、比べて", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "43": {
        "text": "マジで？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "44": {
        "text": "マジです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "45": {
        "text": "２人は笑った", 
        "name": "", 
        "loc": "center"
    }, 
    "46": {
        "text": "一生分を使ってしまったかもしれません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "47": {
        "text": "好きなだけ使ったら、良いじゃないか", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "48": {
        "text": "何ていうか私の言語体系にそぐわないのですよね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "49": {
        "text": "難しい言葉ばかり使っているからじゃないかな？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "50": {
        "text": "できる限り、適切な言葉を運用したいと思っています", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "51": {
        "text": "でもさ、難しすぎると相手に伝わらないんじゃない？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "52": {
        "text": "相手のためだけに言葉を選ぶのではありません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "53": {
        "text": "言葉選びは自分のためでもあるのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "54": {
        "text": "そうやって、考えればよろしいかと", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "55": {
        "text": "そこまで深く考えたことがないな", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "56": {
        "text": "考えてみたらよろしいかと", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "57": {
        "text": "ねぇ、知人と友人を区別することに意味はある？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "58": {
        "text": "意味はありません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "59": {
        "text": "どこからが浜辺で、どこからが海かと尋ねている様なものです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "60": {
        "text": "なるほどね、変動するわけだ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "61": {
        "text": "そう、波動の様なもの", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "62": {
        "text": "より俯瞰した視点に立ったときに境界線がある様に見えるだけのこと", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "63": {
        "text": "要は視点の問題なのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "64": {
        "text": "個別の例をいくら解釈したところで、何も得られません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "65": {
        "text": "誰が１番の親友かなんて議論をしても意味がないわけか", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "66": {
        "text": "意味がないとは言いませんけれどね", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "67": {
        "text": "１番である基準はあまりにも曖昧です", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "68": {
        "text": "少しスッキリしたよ", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "69": {
        "text": "人間関係に悩まれていたのでしょうか？", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "70": {
        "text": "そうかもしれない", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "71": {
        "text": "どうで良いなって、思うことは多々あった", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "72": {
        "text": "ヒエヌキさんみたく考えられたら、楽になれるかもしれない", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "73": {
        "text": "口にしてはいけませんよ", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "74": {
        "text": "ヒエヌキは唇の前に人差し指を立てた", 
        "name": "", 
        "loc": "center"
    }, 
    "75": {
        "text": "口は災いの元ですから", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "76": {
        "text": "他者からの評価を気にしないことです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "77": {
        "text": "それができたら、苦労しないんじゃないか？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "78": {
        "text": "そうかもしれません", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "79": {
        "text": "そういうときは、目を瞑るのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "80": {
        "text": "うん", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "81": {
        "text": "目に浮かぶ大事なことを優先すれば良い", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "82": {
        "text": "それだけです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "83": {
        "text": "色々なものが目に入ってきて、どうしたら良いか分からなくなってしまうのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "84": {
        "text": "自分のやりたい様にすればよろしい", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "85": {
        "text": "それ以外はノイズに等しい", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "86": {
        "text": "私からしたら、多くの人はノイズに惑わされ過ぎなのです", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "87": {
        "text": "本当に高校生？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "88": {
        "text": "そうですよ", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "89": {
        "text": "この春から高校生です", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "90": {
        "text": "恐ろしいな", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "91": {
        "text": "私が？", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "92": {
        "text": "そう", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "93": {
        "text": "では、友人になるのを諦めますか？", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "94": {
        "text": "いや、もっと興味を持った", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "95": {
        "text": "そうですか", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "96": {
        "text": "秘密を知りたくなった", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "97": {
        "text": "秘密ですか", 
        "name": "モミ", 
        "loc": "left"
    }, 
    "98": {
        "text": "あるだろう？", 
        "name": "ユータ", 
        "loc": "right"
    }, 
    "99": {
        "text": "知りたいですか？", 
        "name": "モミ", 
        "loc": "left"
    }
}